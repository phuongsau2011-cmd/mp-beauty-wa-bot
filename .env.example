# Copy file này thành .env rồi điền giá trị thật (KHÔNG commit .env lên git)

# --- Từ Meta (WhatsApp Cloud API) ---
WHATSAPP_TOKEN=       # Access token (nên tạo token vĩnh viễn qua System User)
PHONE_NUMBER_ID=      # Phone number ID của số WhatsApp
VERIFY_TOKEN=         # Chuỗi bất kỳ mình tự đặt, dùng khi cấu hình webhook

# --- Từ Anthropic (Claude API) ---
ANTHROPIC_API_KEY=    # Lấy tại platform.claude.com

# --- Cấu hình chạy ---
PORT=3000
